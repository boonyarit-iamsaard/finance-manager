{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "types:check": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@finance-manager/auth": "workspace:*",
    "@finance-manager/db": "workspace:*",
    "@finance-manager/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "pino": "^10.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@finance-manager/config": "workspace:*",
    "@types/bun": "catalog:",
    "pino-pretty": "^13.1.2",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
